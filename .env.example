# JWT secret for session tokens (change in production!)
JWT_SECRET=dev-secret-change-in-production

# WebAuthn Relying Party configuration
# Local development (defaults if unset when served on localhost):
RP_ID=localhost
RP_NAME=Todo App
RP_ORIGIN=http://localhost:3000

# Production (e.g. Railway): set to your public domain so WebAuthn works.
# If RP_ID/RP_ORIGIN are unset, the app derives them from the request host (recommended for production).
# RP_ID=todo-app-workshop-production.up.railway.app
# RP_ORIGIN=https://todo-app-workshop-production.up.railway.app
